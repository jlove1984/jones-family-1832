# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jones_family_hub"

# Auth (Better Auth)
AUTH_SECRET="your-auth-secret-here"
BETTER_AUTH_SECRET="at-least-32-characters-secret-key-here"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Social login (optional; omit to hide Google/Apple buttons)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
# Required for Apple Sign In with ID Token (e.g. native); use your App Bundle ID
APPLE_APP_BUNDLE_IDENTIFIER=""

# Stripe Payment Processing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@jonesfamily1832.com"

# File Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_REUNION_DATE="2027-07-15"

# Optional: Feature Flags
ENABLE_PAYMENTS="true"
ENABLE_ACHIEVEMENTS="true"
ENABLE_BIRTHDAYS="true"
